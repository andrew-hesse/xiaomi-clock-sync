{
  "name": "xiaomi-clock-sync",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Web Bluetooth utility to sync time to a Xiaomi LYWSD02 clock.",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:icons && tsc --noEmit && vite build",
    "build:icons": "node scripts/build-icons.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/web-bluetooth": "^0.0.20",
    "sharp": "^0.33.5",
    "typescript": "^5.6.0",
    "vite": "^8.0.7",
    "vitest": "^3.0.0"
  }
}
